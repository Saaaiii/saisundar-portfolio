# style.css

```css
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    scroll-behavior:smooth;
}

body{
    font-family:'Poppins',sans-serif;
    background:#050816;
    color:white;
    overflow-x:hidden;
}

.bg-animation{
    position:fixed;
    width:100%;
    height:100%;
    background:linear-gradient(-45deg,#0f172a,#111827,#0f0c29,#302b63);
    background-size:400% 400%;
    animation:gradient 15s ease infinite;
    z-index:-1;
}

@keyframes gradient{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.header{
    position:fixed;
    width:100%;
    padding:20px 10%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    backdrop-filter:blur(12px);
    z-index:1000;
}

.logo{
    color:white;
    text-decoration:none;
    font-size:28px;
    font-weight:700;
}

.logo span{
    color:#00f7ff;
}

.navbar a{
    margin-left:25px;
    color:white;
    text-decoration:none;
    transition:0.3s;
}

.navbar a:hover{
    color:#00f7ff;
}

section{
    min-height:100vh;
    padding:120px 10% 80px;
}

.home{
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
}

.home-content{
    max-width:600px;
}

.home-content h1{
    font-size:70px;
    line-height:1.1;
}

.home-content h2{
    color:#00f7ff;
